# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# ── Supabase PostgreSQL ───────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection pooling → URI (port 6543)
DATABASE_URL=postgresql://postgres.yourprojectref:yourpassword@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=run_node_-e_require('crypto').randomBytes(64).toString('hex')
SESSION_SECRET=run_same_command_again

# ── Admin Defaults ────────────────────────────────────────────────
ADMIN_EMAIL=admin@futurestore.com
ADMIN_PASSWORD=Admin@12345

# ── Payments ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
PAYPAL_CLIENT_ID=your_paypal_client_id

# ── Optional Services ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_key_here
ALGOLIA_APP_ID=your_app_id
ALGOLIA_API_KEY=your_admin_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret
